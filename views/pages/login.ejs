<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Sign In — AlzCloud</title>
  <meta name="description" content="Sign in to your AlzCloud account to manage your files and shareable links.">
  <meta name="robots" content="noindex, nofollow">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233d5afe' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="icon-btn"><i data-lucide="chevron-left"></i></a>
    <a href="/register" class="btn btn-ghost btn-sm">Create account</a>
  </div>
  <main class="app-main no-nav">
    <div class="auth-wrap">
      <div class="auth-logo"><i data-lucide="cloud"></i><span><%= appName %></span></div>
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-sub">Sign in to manage your files</p>

      <% if (error) { %>
        <div class="alert alert-error"><i data-lucide="alert-circle"></i><span><%= error %></span></div>
      <% } %>

      <form method="POST" action="/login">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="hidden" name="next" value="<%= next %>">
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" type="email" name="email" required autofocus placeholder="you@example.com">
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input class="form-input" type="password" name="password" required placeholder="••••••••">
        </div>
        <button type="submit" class="btn btn-primary btn-block">Sign in</button>
      </form>

      <p class="auth-switch">No account? <a href="/register">Create one free</a></p>
    </div>
  </main>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
