<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %> — AlzCloud</title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="logo"><i data-lucide="cloud"></i><span><%= appName %></span></a>
    <div class="topbar-action">
      <span class="badge badge-<%= user.plan %>"><%= user.plan %></span>
      <% if (user.is_admin && locals.adminSlug) { %>
        <a href="/<%= locals.adminSlug %>" class="icon-btn" title="Admin"><i data-lucide="shield"></i></a>
      <% } %>
      <a href="/logout" class="icon-btn"><i data-lucide="log-out"></i></a>
    </div>
  </div>

  <main class="app-main">
    <div class="section" style="padding-bottom:0">
      <div class="card">
        <div class="flex justify-between items-center mb-1">
          <span class="text-sm text-muted">Storage used</span>
          <span class="text-sm" style="font-weight:700"><%= storageUsed %> <span class="text-muted" style="font-weight:500">/ <%= storageMax %></span></span>
        </div>
        <% if (!unlimitedStorage) { %>
          <div class="progress-bar"><div class="progress-fill" style="width:<%= storagePercent %>%"></div></div>
        <% } %>
        <div class="flex gap-3 mt-2 text-sm text-muted">
          <span><i data-lucide="file" style="width:14px;height:14px;vertical-align:-2px"></i> Max <%= fileSizeLimit %>/file</span>
        </div>
      </div>

      <% if (user.plan === 'free') { %>
        <a href="/plans" class="card mt-2" style="display:block;background:linear-gradient(150deg,var(--brand-tint),var(--violet-tint));border:none">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <i data-lucide="zap" style="color:var(--violet)"></i>
              <div>
                <div style="font-weight:700;font-size:.88rem">Upgrade for 2GB uploads + API</div>
                <div class="text-sm text-muted">From ₦3,000/month</div>
              </div>
            </div>
            <i data-lucide="chevron-right" style="color:var(--muted)"></i>
          </div>
        </a>
      <% } else { %>
        <a href="/dashboard/apps" class="card mt-2" style="display:block">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <i data-lucide="key" style="color:var(--brand)"></i>
              <div>
                <div style="font-weight:700;font-size:.88rem"><%= apiApps.length %> API app<%= apiApps.length===1?'':'s' %></div>
                <div class="text-sm text-muted"><%= apiAppsThisMonth %>/<%= limits.maxApiApps %> created this month</div>
              </div>
            </div>
            <i data-lucide="chevron-right" style="color:var(--muted)"></i>
          </div>
        </a>
      <% } %>
    </div>

    <div class="section">
      <div class="flex justify-between items-center mb-2">
        <div class="section-title" style="margin-bottom:0">Your files</div>
        <span class="text-sm text-muted"><%= files.length %> total</span>
      </div>

      <div class="card" style="padding:6px 16px">
        <% if (files.length === 0) { %>
          <div class="empty-state">
            <i data-lucide="inbox"></i>
            <p>No files yet. Tap the + button to upload your first file.</p>
          </div>
        <% } else { %>
          <% files.forEach(f => { %>
            <div class="file-row">
              <div class="file-icon badge-<%= f.file_type %>" style="background:var(--surface)">
                <i data-lucide="<%= f.file_type === 'video' ? 'video' : f.file_type === 'image' ? 'image' : f.file_type === 'audio' ? 'music' : (f.mime_type === 'application/pdf' ? 'file-text' : 'file') %>"></i>
              </div>
              <div class="file-meta">
                <div class="file-name"><%= f.original_name %></div>
                <div class="file-sub"><%= f.sizeFormatted %> · <%= f.downloads %> download<%= f.downloads===1?'':'s' %></div>
              </div>
              <button class="icon-btn" data-copy="<%= appUrl %>/f/<%= f.slug %>"><i data-lucide="copy"></i></button>
              <a href="/f/<%= f.slug %>" class="icon-btn"><i data-lucide="external-link"></i></a>
              <button class="icon-btn danger" data-delete-file="<%= f.id %>" data-name="<%= f.original_name %>"><i data-lucide="trash-2"></i></button>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <p class="mini-footer">&copy; <%= new Date().getFullYear() %> <%= appName %></p>
  </main>

  <button class="fab" id="upload-zone" data-endpoint="/upload" data-max-bytes="<%= limits.fileSize %>">
    <i data-lucide="plus"></i>
  </button>
  <input type="file" id="file-input" style="display:none">

  <%- include('../partials/tabbar', { active: 'files', user }) %>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
