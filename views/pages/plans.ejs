<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Pricing Plans — AlzCloud</title>
  <meta name="description" content="Simple pricing. Free unlimited storage at 500MB per file. Starter ₦3,000/mo for 1GB uploads + API. Pro ₦5,000/mo for 2GB uploads + more API apps.">
  <link rel="canonical" href="https://cloud.alz.name.ng/plans">
  <meta name="robots" content="index, follow">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233d5afe' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .faq-item { border-bottom: 1px solid var(--border); padding: 14px 0; }
    .faq-q { font-weight: 600; font-size: .86rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .faq-q i { width: 16px; height: 16px; color: var(--muted); transition: transform .2s; }
    .faq-item.open .faq-q i { transform: rotate(180deg); }
    .faq-a { font-size: .82rem; color: var(--muted); margin-top: 8px; display: none; line-height: 1.6; }
    .faq-item.open .faq-a { display: block; }
  </style>
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="logo"><i data-lucide="cloud"></i><span><%= appName %></span></a>
    <% if (locals.user) { %><a href="/dashboard" class="btn btn-outline btn-sm">Dashboard</a>
    <% } else { %><a href="/register" class="btn btn-primary btn-sm">Get started</a><% } %>
  </div>

  <main class="app-main">
    <div class="section text-center" style="padding-bottom:0">
      <h1 style="font-size:1.5rem">Simple, honest pricing</h1>
      <p class="text-muted text-sm mt-1">Upgrade or downgrade anytime.</p>

      <% if (locals.queryError) { %>
        <div class="alert alert-error mt-2"><i data-lucide="alert-circle"></i><span>Payment failed or was cancelled. Please try again.</span></div>
      <% } %>

      <div class="cycle-toggle" id="cycle-toggle">
        <button class="active" data-cycle="monthly">Monthly</button>
        <button data-cycle="yearly">Yearly <span class="cycle-save">save ~30%</span></button>
      </div>
    </div>

    <div class="section" style="padding-top:0">
      <% plans.forEach(function(plan) {
        var featured = plan.name === 'starter';
        var isCurrentPlan = locals.user && locals.user.plan === plan.name;
        var features = [];
        try { features = JSON.parse(plan.features || '[]'); } catch(e) { features = []; }
      %>
      <div class="plan-card <%= featured ? 'featured' : '' %>">
        <% if (featured) { %><div class="plan-badge">Most Popular</div><% } %>
        <div class="plan-name"><%= plan.display_name %></div>
        <% if (plan.price_ngn === 0) { %>
          <div class="plan-price">Free</div>
          <div class="plan-sub">Forever</div>
        <% } else { %>
          <div class="plan-price" data-monthly="&#8358;<%= Number(plan.price_ngn).toLocaleString() %>" data-yearly="&#8358;<%= Number(plan.price_ngn_yearly).toLocaleString() %>">&#8358;<%= Number(plan.price_ngn).toLocaleString() %><span class="price-period">/month</span></div>
          <div class="plan-sub price-sub">Billed monthly</div>
        <% } %>
        <ul class="plan-features">
          <% features.forEach(function(f) { %>
          <li><i data-lucide="check"></i><%= f %></li>
          <% }); %>
        </ul>
        <% if (isCurrentPlan) { %>
          <div class="btn btn-outline btn-block" style="cursor:default"><i data-lucide="check"></i> Current plan</div>
        <% } else if (plan.price_ngn === 0) { %>
          <a href="/register" class="btn btn-outline btn-block">Get started free</a>
        <% } else if (locals.user) { %>
          <a href="/billing/upgrade/<%= plan.name %>/monthly" class="btn <%= featured ? 'btn-primary' : 'btn-outline' %> btn-block upgrade-link" data-monthly-href="/billing/upgrade/<%= plan.name %>/monthly" data-yearly-href="/billing/upgrade/<%= plan.name %>/yearly">Upgrade to <%= plan.display_name %></a>
        <% } else { %>
          <a href="/register" class="btn <%= featured ? 'btn-primary' : 'btn-outline' %> btn-block">Get started</a>
        <% } %>
      </div>
      <% }); %>
    </div>

    <div class="section">
      <div class="section-title">FAQ</div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What counts toward storage?<i data-lucide="chevron-down"></i></div>
        <div class="faq-a">Every file you upload counts toward your storage limit. Free has no total storage cap, just a 500MB-per-file limit. Deleting a file frees up space immediately.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What's an API app?<i data-lucide="chevron-down"></i></div>
        <div class="faq-a">Starter and Pro can create named API apps, each with its own key, to upload and manage files from your own software. Starter gets 5 new apps/month, Pro gets 10. See the <a href="/api">API docs</a>.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What happens when my plan expires?<i data-lucide="chevron-down"></i></div>
        <div class="faq-a">Your API apps stop working until you renew, but you can still upload manually from the dashboard at Free-tier limits — nothing you've already uploaded is deleted.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">How do payments work?<i data-lucide="chevron-down"></i></div>
        <div class="faq-a">All payments are processed securely via Paystack — card, bank transfer, or USSD.</div>
      </div>
    </div>
    <p class="mini-footer">&copy; <%= new Date().getFullYear() %> <%= appName %></p>
  </main>

  <%- include('../partials/tabbar', { active: 'plans', user: locals.user }) %>
</div>
<%- include('../partials/scripts') %>
<script>
function toggleFaq(el) { el.closest('.faq-item').classList.toggle('open'); }
document.getElementById('cycle-toggle')?.addEventListener('click', e => {
  const btn = e.target.closest('button');
  if (!btn) return;
  const cycle = btn.dataset.cycle;
  document.querySelectorAll('#cycle-toggle button').forEach(b => b.classList.toggle('active', b === btn));
  document.querySelectorAll('.plan-price[data-monthly]').forEach(el => {
    el.querySelector('.price-period').outerHTML = cycle === 'yearly' ? '<span class="price-period">/year</span>' : '<span class="price-period">/month</span>';
    el.childNodes[0].textContent = cycle === 'yearly' ? el.dataset.yearly : el.dataset.monthly;
  });
  document.querySelectorAll('.price-sub').forEach(el => { el.textContent = cycle === 'yearly' ? 'Billed yearly' : 'Billed monthly'; });
  document.querySelectorAll('.upgrade-link').forEach(el => { el.href = cycle === 'yearly' ? el.dataset.yearlyHref : el.dataset.monthlyHref; });
});
</script>
</body>
</html>
