<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>API Documentation — AlzCloud</title>
  <meta name="description" content="AlzCloud REST API docs. Create named API apps and upload, list, and delete files programmatically.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://cloud.alz.name.ng/api">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233d5afe' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .jump-row { display: flex; gap: 6px; overflow-x: auto; padding: 2px 0 4px; -webkit-overflow-scrolling: touch; }
    .jump-row a { flex-shrink: 0; background: var(--surface); border-radius: var(--radius-pill); padding: 6px 13px; font-size: .76rem; font-weight: 600; color: var(--muted); white-space: nowrap; }
    .api-h2 { font-size: 1.02rem; margin: 26px 0 10px; padding-top: 20px; border-top: 1px solid var(--border); scroll-margin-top: 60px; }
    .section:first-of-type .api-h2:first-child { border-top: none; padding-top: 0; }
    .endpoint { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 12px; overflow: hidden; }
    .endpoint-header { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--border); flex-wrap: wrap; }
    .method { font-size: .68rem; font-weight: 700; padding: 3px 8px; border-radius: 5px; font-family: 'JetBrains Mono', monospace; }
    .method-get { background: var(--success-tint); color: var(--success); }
    .method-post { background: var(--brand-tint); color: var(--brand-dark); }
    .method-delete { background: var(--danger-tint); color: var(--danger); }
    .endpoint-path { font-family: 'JetBrains Mono', monospace; font-size: .78rem; }
    .endpoint-desc { font-size: .74rem; color: var(--muted-2); width: 100%; }
    .endpoint-body { padding: 12px 14px; }
    .endpoint-body pre { margin: 8px 0; font-size: .72rem; }
    .param-table { width: 100%; border-collapse: collapse; font-size: .78rem; margin: 8px 0; }
    .param-table th { text-align: left; padding: 6px 8px; font-size: .68rem; color: var(--muted); border-bottom: 1px solid var(--border); text-transform: uppercase; }
    .param-table td { padding: 7px 8px; border-bottom: 1px solid var(--border); }
    .param-name { font-family: 'JetBrains Mono', monospace; color: var(--brand-dark); font-size: .74rem; }
  </style>
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="logo"><i data-lucide="cloud"></i><span><%= appName %></span></a>
    <% if (locals.user) { %><a href="/dashboard/apps" class="btn btn-outline btn-sm">My apps</a>
    <% } else { %><a href="/register" class="btn btn-primary btn-sm">Get started</a><% } %>
  </div>

  <main class="app-main">
    <div class="section" style="padding-bottom:0">
      <h1 style="font-size:1.35rem">AlzCloud API</h1>
      <p class="text-sm text-muted mb-2">Programmatic file storage — available on <strong>Starter</strong> and <strong>Pro</strong>. Manage keys under <a href="/dashboard/apps">My Apps</a>.</p>
      <div class="jump-row">
        <a href="#auth">Auth</a><a href="#errors">Errors</a><a href="#me">Account</a><a href="#storage">Storage</a><a href="#list">List</a><a href="#upload">Upload</a><a href="#update">Update</a><a href="#delete">Delete</a>
      </div>
    </div>

    <div class="section">
      <div class="alert alert-info"><i data-lucide="info"></i><span>Base URL: <code><%= appUrl %>/api/v1</code></span></div>

      <h2 class="api-h2" id="auth">Authentication</h2>
      <p class="text-sm text-muted mb-1">Each API app you create has its own key. Pass it as a header:</p>
      <pre><code>X-API-Key: your_app_key</code></pre>
      <p class="text-sm text-muted mb-1">Or as a query param (less secure):</p>
      <pre><code>GET /api/v1/files?api_key=your_app_key</code></pre>

      <h2 class="api-h2" id="errors">Error codes</h2>
      <table class="param-table">
        <thead><tr><th>Code</th><th>Meaning</th></tr></thead>
        <tbody>
          <tr><td class="param-name">401</td><td>Missing, invalid, or revoked API key</td></tr>
          <tr><td class="param-name">403</td><td>API access not on your plan, or app quota reached</td></tr>
          <tr><td class="param-name">404</td><td>File not found</td></tr>
          <tr><td class="param-name">400</td><td>Bad request (missing fields, file too large)</td></tr>
          <tr><td class="param-name">429</td><td>Rate limited — slow down</td></tr>
          <tr><td class="param-name">500</td><td>Server error — try again later</td></tr>
        </tbody>
      </table>

      <h2 class="api-h2" id="me">Account info</h2>
      <div class="endpoint">
        <div class="endpoint-header"><span class="method method-get">GET</span><span class="endpoint-path">/api/v1/me</span><span class="endpoint-desc">Your account + plan details</span></div>
        <div class="endpoint-body">
          <pre><code>curl <%= appUrl %>/api/v1/me \
  -H "X-API-Key: your_app_key"</code></pre>
          <pre><code>{
  "id": 1,
  "username": "yourname",
  "plan": "starter",
  "api_app": "My Mobile App",
  "storage_used_human": "10 MB",
  "storage_limit_human": "100 GB"
}</code></pre>
        </div>
      </div>

      <h2 class="api-h2" id="storage">Storage usage</h2>
      <div class="endpoint">
        <div class="endpoint-header"><span class="method method-get">GET</span><span class="endpoint-path">/api/v1/storage</span><span class="endpoint-desc">Storage breakdown</span></div>
        <div class="endpoint-body">
          <pre><code>{
  "used_human": "10 MB",
  "limit_human": "100 GB",
  "remaining_human": "99.9 GB",
  "percent": 0
}</code></pre>
        </div>
      </div>

      <h2 class="api-h2" id="list">List files</h2>
      <p class="text-sm text-muted mb-1">Scoped to the calling app's key — you'll only see files this specific app uploaded, not other apps on your account or your dashboard uploads.</p>
      <div class="endpoint">
        <div class="endpoint-header">
          <span class="method method-get">GET</span><span class="endpoint-path">/api/v1/files</span><span class="endpoint-desc">List files uploaded by this app's key</span>
        </div>
        <div class="endpoint-body">
          <table class="param-table">
            <thead><tr><th>Param</th><th>Default</th></tr></thead>
            <tbody>
              <tr><td class="param-name">limit</td><td>20 (max 100)</td></tr>
              <tr><td class="param-name">offset</td><td>0</td></tr>
            </tbody>
          </table>
          <pre><code>{
  "files": [{
    "name": "video.mp4",
    "slug": "abc123def456",
    "size_human": "50 MB",
    "file_type": "video",
    "is_public": true,
    "url": "<%= appUrl %>/f/abc123def456",
    "download_url": "<%= appUrl %>/api/your_username/your-app-name/abc123def456/video.mp4",
    "embed_url": "<%= appUrl %>/embed/abc123def456"
  }],
  "total": 42, "limit": 20, "offset": 0
}</code></pre>
        </div>
      </div>

      <h2 class="api-h2" id="upload">Upload file</h2>
      <div class="endpoint">
        <div class="endpoint-header"><span class="method method-post">POST</span><span class="endpoint-path">/api/v1/upload</span><span class="endpoint-desc">multipart/form-data, field "file"</span></div>
        <div class="endpoint-body">
          <pre><code>curl -X POST <%= appUrl %>/api/v1/upload \
  -H "X-API-Key: your_app_key" \
  -F "file=@/path/to/video.mp4"</code></pre>
          <pre><code>const form = new FormData();
form.append('file', fileBlob, 'myfile.mp4');
const res = await fetch('<%= appUrl %>/api/v1/upload', {
  method: 'POST',
  headers: { 'X-API-Key': 'your_app_key' },
  body: form,
});</code></pre>
        </div>
      </div>

      <h2 class="api-h2" id="update">Update file</h2>
      <p class="text-sm text-muted mb-1">Rename a file and/or toggle its public visibility. Send only the fields you want to change.</p>
      <div class="endpoint">
        <div class="endpoint-header"><span class="method method-post" style="background:var(--warning-tint);color:var(--warning)">PATCH</span><span class="endpoint-path">/api/v1/files/:slug</span><span class="endpoint-desc"></span></div>
        <div class="endpoint-body">
          <pre><code>curl -X PATCH <%= appUrl %>/api/v1/files/abc123def456 \
  -H "X-API-Key: your_app_key" \
  -H "Content-Type: application/json" \
  -d '{"name": "renamed.mp4", "is_public": false}'</code></pre>
        </div>
      </div>

      <h2 class="api-h2" id="delete">Delete file</h2>
      <div class="endpoint">
        <div class="endpoint-header"><span class="method method-delete">DELETE</span><span class="endpoint-path">/api/v1/files/:slug</span><span class="endpoint-desc"></span></div>
        <div class="endpoint-body">
          <pre><code>curl -X DELETE <%= appUrl %>/api/v1/files/abc123def456 \
  -H "X-API-Key: your_app_key"</code></pre>
        </div>
      </div>
    </div>
    <p class="mini-footer">&copy; <%= new Date().getFullYear() %> <%= appName %></p>
  </main>

  <%- include('../partials/tabbar', { active: 'api', user: locals.user }) %>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
