<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Center — <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.1/lucide.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.1/umd/lucide.min.js"></script>
  <style>
    .admin-shell { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
    .admin-sidebar {
      background: var(--bg2);
      border-right: 1px solid var(--border);
      padding: 1.5rem 0;
      position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }
    .admin-logo { padding: 0 1.25rem 1.5rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
    .admin-logo h2 { font-size: 1rem; font-weight: 700; color: var(--accent2); }
    .admin-logo p { font-size: 0.72rem; color: var(--muted); margin-top: 2px; }
    .sidebar-section { padding: 0 0.75rem; margin-bottom: 0.25rem; }
    .sidebar-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); padding: 0.5rem 0.5rem 0.25rem; font-weight: 600; }
    .sidebar-link {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.55rem 0.75rem; border-radius: var(--radius-sm);
      font-size: 0.855rem; color: var(--muted); cursor: pointer;
      transition: all .15s; text-decoration: none; border: none; background: none; width: 100%;
    }
    .sidebar-link:hover, .sidebar-link.active { background: var(--accent-glow); color: var(--accent2); }
    .sidebar-link svg { width: 15px; height: 15px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid var(--border); margin-top: auto; }

    .admin-main { background: var(--bg); overflow: auto; }
    .admin-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem; border-bottom: 1px solid var(--border);
      background: var(--bg); position: sticky; top: 0; z-index: 50;
    }
    .admin-topbar h1 { font-size: 1.1rem; font-weight: 600; }
    .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); animation: pulse-dot 1.5s infinite; display: inline-block; margin-right: 6px; }
    @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.3)} }

    .admin-content { padding: 2rem; }

    /* Sections */
    .admin-section { display: none; }
    .admin-section.active { display: block; }

    /* Stat cards heartbeat style */
    .hb-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .hb-card {
      background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem;
      position: relative; overflow: hidden; transition: border-color .3s;
    }
    .hb-card:hover { border-color: var(--accent); }
    .hb-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transform: scaleX(0); transform-origin: left; transition: transform .4s;
    }
    .hb-card:hover::after { transform: scaleX(1); }
    .hb-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.85rem; }
    .hb-icon svg { width: 18px; height: 18px; }
    .hb-icon.purple { background: #6c63ff22; color: var(--accent2); }
    .hb-icon.green { background: #22d3a022; color: var(--green); }
    .hb-icon.blue { background: #06b6d422; color: #22d3ee; }
    .hb-icon.yellow { background: #f5c84222; color: var(--yellow); }
    .hb-icon.red { background: #ff4d6a22; color: var(--red); }
    .hb-val { font-size: 1.85rem; font-weight: 700; line-height: 1; color: var(--text); font-variant-numeric: tabular-nums; }
    .hb-label { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }
    .hb-delta { font-size: 0.72rem; margin-top: 0.4rem; color: var(--green); }
    .hb-delta.neg { color: var(--red); }

    /* Plan donut / breakdown */
    .plan-breakdown { display: flex; flex-direction: column; gap: 0.6rem; }
    .plan-row { display: flex; align-items: center; gap: 0.75rem; }
    .plan-row-bar { flex: 1; height: 6px; background: var(--bg3); border-radius: 99px; overflow: hidden; }
    .plan-row-fill { height: 100%; border-radius: 99px; }
    .fill-free { background: var(--muted); }
    .fill-starter { background: var(--accent2); }
    .fill-pro { background: var(--green); }
    .plan-row-name { font-size: 0.78rem; color: var(--muted); width: 55px; text-transform: capitalize; }
    .plan-row-count { font-size: 0.78rem; font-weight: 600; color: var(--text); width: 30px; text-align: right; }

    /* Two col layout */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    @media(max-width:900px){ .two-col{ grid-template-columns:1fr; } .admin-shell{ grid-template-columns:1fr; } .admin-sidebar{display:none;} }

    /* Recent users table in dashboard */
    .mini-table { width: 100%; border-collapse: collapse; }
    .mini-table th { text-align: left; padding: 0.5rem 0.75rem; font-size: 0.72rem; color: var(--muted); font-weight: 600; border-bottom: 1px solid var(--border); text-transform: uppercase; letter-spacing: .04em; }
    .mini-table td { padding: 0.65rem 0.75rem; font-size: 0.82rem; border-bottom: 1px solid var(--border); }
    .mini-table tr:last-child td { border-bottom: none; }
    .mini-table tr:hover td { background: var(--bg3); }

    .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
    .badge-free { background: var(--bg3); color: var(--muted); }
    .badge-starter { background: #6c63ff22; color: var(--accent2); }
    .badge-pro { background: #22d3a022; color: var(--green); }

    /* Plan editor */
    .plan-editor-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; margin-bottom: 1.5rem; }
    .plan-editor-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
    .plan-editor-card h4 { font-size: 0.9rem; font-weight: 600; margin-bottom: 1rem; color: var(--accent2); display: flex; align-items: center; gap: 0.5rem; }
    .plan-editor-card h4 svg { width: 15px; height: 15px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .toggle-row { display: flex; align-items: center; justify-content: space-between; margin-top: 0.75rem; padding-top: 0.75rem; border-top: 1px solid var(--border); }
    .toggle-label { font-size: 0.82rem; color: var(--muted); }
    .toggle { position: relative; width: 38px; height: 20px; }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider { position: absolute; inset: 0; background: var(--bg3); border-radius: 99px; cursor: pointer; transition: .2s; border: 1px solid var(--border2); }
    .toggle-slider::before { content:''; position: absolute; width: 14px; height: 14px; left: 2px; bottom: 2px; background: var(--muted); border-radius: 50%; transition: .2s; }
    .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
    .toggle input:checked + .toggle-slider::before { transform: translateX(18px); background: #fff; }

    /* Styled modal */
    .modal-overlay { position: fixed; inset: 0; background: #00000088; display: flex; align-items: center; justify-content: center; z-index: 1000; opacity: 0; pointer-events: none; transition: opacity .2s; }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal-box { background: var(--bg2); border: 1px solid var(--border2); border-radius: var(--radius); padding: 1.75rem; min-width: 340px; max-width: 480px; width: 90%; transform: scale(.96); transition: transform .2s; }
    .modal-overlay.open .modal-box { transform: scale(1); }
    .modal-title { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
    .modal-body { font-size: 0.875rem; color: var(--muted); margin-bottom: 1.5rem; }
    .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; }

    .user-search-bar { display: flex; gap: 0.75rem; margin-bottom: 1.25rem; }
    .user-search-bar input, .user-search-bar select { flex: 1; }
  </style>
</head>
<body>
<div class="admin-shell">

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-logo">
      <h2><%= appName %> Admin</h2>
      <p>Management Center</p>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Overview</div>
      <button class="sidebar-link active" onclick="showSection('dashboard', this)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </button>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">Management</div>
      <button class="sidebar-link" onclick="showSection('users', this)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users
      </button>
      <button class="sidebar-link" onclick="showSection('plans', this)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Plans & Pricing
      </button>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-label">System</div>
      <a href="/dashboard" class="sidebar-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Main Site
      </a>
      <a href="/logout" class="sidebar-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign Out
      </a>
    </div>
    <div class="sidebar-footer">
      <div style="font-size:.72rem;color:var(--muted)">Signed in as</div>
      <div style="font-size:.82rem;font-weight:600;color:var(--text);margin-top:2px"><%= adminUser.username %></div>
    </div>
  </aside>

  <!-- Main -->
  <div class="admin-main">
    <div class="admin-topbar">
      <h1 id="section-title">Dashboard</h1>
      <div style="display:flex;align-items:center;gap:1rem">
        <span style="font-size:.8rem;color:var(--muted)"><span class="live-dot"></span>Live</span>
        <span id="live-clock" style="font-size:.8rem;color:var(--muted);font-variant-numeric:tabular-nums"></span>
      </div>
    </div>

    <div class="admin-content">

      <!-- ── DASHBOARD SECTION ── -->
      <div class="admin-section active" id="section-dashboard">

        <!-- Heartbeat stat cards -->
        <div class="hb-grid">
          <div class="hb-card">
            <div class="hb-icon purple"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
            <div class="hb-val" id="stat-users"><%= stats.users %></div>
            <div class="hb-label">Total Users</div>
            <div class="hb-delta">+<%= stats.newUsersToday %> today</div>
          </div>
          <div class="hb-card">
            <div class="hb-icon blue"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg></div>
            <div class="hb-val" id="stat-files"><%= stats.files %></div>
            <div class="hb-label">Files Stored</div>
            <div class="hb-delta">+<%= stats.filesThisWeek %> this week</div>
          </div>
          <div class="hb-card">
            <div class="hb-icon yellow"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg></div>
            <div class="hb-val" id="stat-storage"><%= stats.storage %></div>
            <div class="hb-label">Storage Used</div>
          </div>
          <div class="hb-card">
            <div class="hb-icon green"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
            <div class="hb-val" id="stat-revenue">&#8358;<%= stats.revenue.toLocaleString() %></div>
            <div class="hb-label">Total Revenue</div>
          </div>
          <div class="hb-card">
            <div class="hb-icon red"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            <div class="hb-val" id="stat-api">—</div>
            <div class="hb-label">API Calls (24h)</div>
          </div>
        </div>

        <div class="two-col">
          <!-- Plan breakdown -->
          <div class="card">
            <h3 style="font-size:.95rem;font-weight:600;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
              Users by Plan
            </h3>
            <div class="plan-breakdown">
              <% var total = planBreakdown.reduce((a,p) => a + parseInt(p.count), 0) || 1; %>
              <% planBreakdown.forEach(function(p) { var pct = Math.round(parseInt(p.count)/total*100); %>
              <div class="plan-row">
                <span class="plan-row-name"><%= p.plan %></span>
                <div class="plan-row-bar"><div class="plan-row-fill fill-<%= p.plan %>" style="width:<%= pct %>%"></div></div>
                <span class="plan-row-count"><%= p.count %></span>
              </div>
              <% }); %>
            </div>
          </div>

          <!-- Top downloaded files -->
          <div class="card">
            <h3 style="font-size:.95rem;font-weight:600;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Top Downloaded
            </h3>
            <% if (topFiles.length === 0) { %>
              <p style="font-size:.82rem;color:var(--muted)">No downloads yet.</p>
            <% } else { %>
            <table class="mini-table">
              <thead><tr><th>File</th><th>Type</th><th>Downloads</th></tr></thead>
              <tbody>
                <% topFiles.forEach(function(f) { %>
                <tr>
                  <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= f.original_name %></td>
                  <td><span class="badge badge-<%= f.file_type || 'document' %>"><%= f.file_type || 'file' %></span></td>
                  <td><%= f.downloads %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
            <% } %>
          </div>
        </div>

        <!-- Recent users -->
        <div class="card">
          <h3 style="font-size:.95rem;font-weight:600;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Recent Sign-ups
          </h3>
          <table class="mini-table">
            <thead><tr><th>Username</th><th>Email</th><th>Plan</th><th>Joined</th></tr></thead>
            <tbody>
              <% recentUsers.forEach(function(u) { %>
              <tr>
                <td style="font-weight:500"><%= u.username %></td>
                <td style="color:var(--muted)"><%= u.email %></td>
                <td><span class="badge badge-<%= u.plan %>"><%= u.plan %></span></td>
                <td style="color:var(--muted)"><%= u.joinedDate %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ── USERS SECTION ── -->
      <div class="admin-section" id="section-users">
        <div class="user-search-bar">
          <input type="text" class="form-input" id="user-search" placeholder="Search username or email..." oninput="filterUsers()">
          <select class="form-input" id="plan-filter" onchange="filterUsers()" style="max-width:160px">
            <option value="">All plans</option>
            <option value="free">Free</option>
            <option value="starter">Starter</option>
            <option value="pro">Pro</option>
          </select>
        </div>
        <div class="card" style="padding:0;overflow:hidden">
          <table class="mini-table" id="users-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Plan</th>
                <th>Storage</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="users-tbody">
              <% users.forEach(function(u) { %>
              <tr data-username="<%= u.username %>" data-email="<%= u.email %>" data-plan="<%= u.plan %>">
                <td style="font-weight:500"><%= u.username %> <% if(u.is_admin){ %><span class="badge" style="background:var(--accent-glow);color:var(--accent2)">Admin</span><% } %></td>
                <td style="color:var(--muted);font-size:.8rem"><%= u.email %></td>
                <td>
                  <select class="form-input" style="padding:.25rem .5rem;font-size:.78rem;width:auto" onchange="changePlan(<%= u.id %>, this.value)" <% if(u.isProtected){ %>disabled<% } %>>
                    <option value="free" <%=u.plan==='free'?'selected':''%>>Free</option>
                    <option value="starter" <%=u.plan==='starter'?'selected':''%>>Starter</option>
                    <option value="pro" <%=u.plan==='pro'?'selected':''%>>Pro</option>
                  </select>
                </td>
                <td style="font-size:.8rem;color:var(--muted)"><%= u.storageFormatted %></td>
                <td style="font-size:.78rem;color:var(--muted)"><%= u.joinedDate %></td>
                <td>
                  <% if(!u.isProtected) { %>
                  <button class="btn btn-danger btn-sm" onclick="confirmDeleteUser(<%= u.id %>, '<%= u.username %>')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                    Delete
                  </button>
                  <% } else { %>
                  <span style="font-size:.75rem;color:var(--muted)">Protected</span>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ── PLANS SECTION ── -->
      <div class="admin-section" id="section-plans">
        <p style="font-size:.85rem;color:var(--muted);margin-bottom:1.5rem">Edit plan limits and features. Changes apply immediately to all new uploads.</p>
        <div class="plan-editor-grid">
          <% plans.forEach(function(plan) { %>
          <div class="plan-editor-card">
            <h4>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <%= plan.display_name %>
            </h4>
            <div class="form-group">
              <label class="form-label">Display Name</label>
              <input type="text" class="form-input" id="plan-<%= plan.name %>-display" value="<%= plan.display_name %>">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Price (&#8358;/mo)</label>
                <input type="number" class="form-input" id="plan-<%= plan.name %>-price" value="<%= plan.price_ngn %>">
              </div>
              <div class="form-group">
                <label class="form-label">Max file (GB)</label>
                <input type="number" step="0.1" class="form-input" id="plan-<%= plan.name %>-filesize" value="<%= (plan.file_size_limit / 1073741824).toFixed(1) %>">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Total storage (GB)</label>
              <input type="number" step="1" class="form-input" id="plan-<%= plan.name %>-storage" value="<%= (plan.storage_limit / 1073741824).toFixed(0) %>">
            </div>
            <div class="toggle-row">
              <span class="toggle-label">API Access</span>
              <label class="toggle">
                <input type="checkbox" id="plan-<%= plan.name %>-api" <%=plan.api_access?'checked':''%>>
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="toggle-row">
              <span class="toggle-label">Live Streaming</span>
              <label class="toggle">
                <input type="checkbox" id="plan-<%= plan.name %>-stream" <%=plan.live_streaming?'checked':''%>>
                <span class="toggle-slider"></span>
              </label>
            </div>
            <button class="btn btn-primary btn-block" style="margin-top:1rem" onclick="savePlan('<%= plan.name %>')">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Save Changes
            </button>
          </div>
          <% }); %>
        </div>
      </div>

    </div><!-- /admin-content -->
  </div><!-- /admin-main -->
</div><!-- /admin-shell -->

<!-- Confirm Delete Modal -->
<div class="modal-overlay" id="delete-modal">
  <div class="modal-box">
    <div class="modal-title">Delete User</div>
    <div class="modal-body" id="delete-modal-body">Are you sure you want to delete this user? All their files will be permanently removed.</div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancel</button>
      <button class="btn btn-danger" id="delete-confirm-btn">Delete</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast" style="position:fixed;bottom:1.5rem;right:1.5rem;background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:.75rem 1.25rem;font-size:.875rem;color:var(--text);z-index:9999;transform:translateY(80px);opacity:0;transition:all .3s;pointer-events:none;max-width:320px"></div>

<script>
const ADMIN_SLUG = '<%= locals.adminSlug %>';

// Section navigation
function showSection(name, el) {
  document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
  document.getElementById('section-' + name).classList.add('active');
  document.getElementById('section-title').textContent = el.textContent.trim();
  el.classList.add('active');
}

// Live clock
function updateClock() {
  document.getElementById('live-clock').textContent = new Date().toLocaleTimeString();
}
setInterval(updateClock, 1000); updateClock();

// Live stats heartbeat (every 15s)
async function refreshStats() {
  try {
    const r = await fetch('/' + ADMIN_SLUG + '/stats');
    const d = await r.json();
    if (d.users !== undefined) document.getElementById('stat-users').textContent = d.users;
    if (d.files !== undefined) document.getElementById('stat-files').textContent = d.files;
    if (d.revenue !== undefined) document.getElementById('stat-revenue').textContent = '₦' + d.revenue.toLocaleString();
    if (d.apiCalls24h !== undefined) document.getElementById('stat-api').textContent = d.apiCalls24h;
  } catch(e) {}
}
setInterval(refreshStats, 15000);

// Toast
function showToast(msg, ok = true) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.borderColor = ok ? 'var(--green)' : 'var(--red)';
  t.style.color = ok ? 'var(--green)' : 'var(--red)';
  t.style.transform = 'translateY(0)';
  t.style.opacity = '1';
  setTimeout(() => { t.style.transform = 'translateY(80px)'; t.style.opacity = '0'; }, 3000);
}

// Delete user
let pendingDeleteId = null;
function confirmDeleteUser(id, username) {
  pendingDeleteId = id;
  document.getElementById('delete-modal-body').textContent = `Delete user "${username}"? All their files will be permanently removed.`;
  document.getElementById('delete-modal').classList.add('open');
  document.getElementById('delete-confirm-btn').onclick = doDeleteUser;
}
function closeModal() {
  document.getElementById('delete-modal').classList.remove('open');
  pendingDeleteId = null;
}
async function doDeleteUser() {
  if (!pendingDeleteId) return;
  closeModal();
  const r = await fetch('/' + ADMIN_SLUG + '/users/' + pendingDeleteId, { method: 'DELETE' });
  const d = await r.json();
  if (d.success) {
    showToast('User deleted.');
    document.querySelector(`[data-username] button[onclick*="${pendingDeleteId}"]`)?.closest('tr')?.remove();
  } else {
    showToast(d.error || 'Delete failed.', false);
  }
}

// Change plan
async function changePlan(id, plan) {
  const r = await fetch('/' + ADMIN_SLUG + '/users/' + id + '/plan', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ plan })
  });
  const d = await r.json();
  showToast(d.success ? 'Plan updated.' : (d.error || 'Failed.'), d.success);
}

// Save plan
async function savePlan(name) {
  const body = {
    display_name: document.getElementById('plan-' + name + '-display').value,
    price_ngn: document.getElementById('plan-' + name + '-price').value,
    storage_limit_gb: document.getElementById('plan-' + name + '-storage').value,
    file_size_limit_gb: document.getElementById('plan-' + name + '-filesize').value,
    api_access: document.getElementById('plan-' + name + '-api').checked,
    live_streaming: document.getElementById('plan-' + name + '-stream').checked,
  };
  const r = await fetch('/' + ADMIN_SLUG + '/plans/' + name, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
  });
  const d = await r.json();
  showToast(d.success ? 'Plan saved!' : (d.error || 'Failed.'), d.success);
}

// User search filter (client-side)
function filterUsers() {
  const search = document.getElementById('user-search').value.toLowerCase();
  const plan = document.getElementById('plan-filter').value;
  document.querySelectorAll('#users-tbody tr').forEach(row => {
    const name = row.dataset.username || '';
    const email = row.dataset.email || '';
    const rowPlan = row.dataset.plan || '';
    const matchSearch = !search || name.includes(search) || email.includes(search);
    const matchPlan = !plan || rowPlan === plan;
    row.style.display = matchSearch && matchPlan ? '' : 'none';
  });
}

// Close modal on overlay click
document.getElementById('delete-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
</body>
</html>
