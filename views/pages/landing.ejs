<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236c63ff' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
</head>
<body>

<nav>
  <a href="/" class="logo"><svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/></svg><span><%= appName %></span></a>
  <div class="nav-links">
    <a href="/plans">Pricing</a>
    <% if (user) { %>
      <a href="/dashboard">Dashboard</a>
      <a href="/logout" class="btn btn-outline btn-sm">Sign out</a>
    <% } else { %>
      <a href="/login">Sign in</a>
      <a href="/register" class="btn btn-primary btn-sm">Get started</a>
    <% } %>
  </div>
</nav>

<div class="container">
  <div class="hero">
    <div class="hero-badge">Fast &amp; Reliable Cloud Storage</div>
    <h1>Store files, images &amp; videos<br><span class="accent">without limits</span></h1>
    <p>Upload once, share anywhere. AlzCloud gives you fast, reliable file hosting with instant shareable links.</p>
    <div class="hero-actions">
      <a href="/register" class="btn btn-primary">Start free &rarr;</a>
      <a href="/plans" class="btn btn-outline">View pricing</a>
    </div>
  </div>

  <div class="stats-grid" style="max-width:700px;margin:0 auto 4rem;">
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">100GB</div>
      <div class="stat-label">Max storage (Business)</div>
    </div>
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">2GB</div>
      <div class="stat-label">Max file size (Business)</div>
    </div>
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">Free</div>
      <div class="stat-label">To get started</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-bottom:4rem;">
    <div class="card">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:.75rem;color:var(--accent2)"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
      <h3 style="margin-bottom:.4rem">Any file type</h3>
      <p class="text-muted text-sm">Documents, images, videos, audio — upload anything and we handle the rest.</p>
    </div>
    <div class="card">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:.75rem;color:var(--accent2)"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <h3 style="margin-bottom:.4rem">Instant public links</h3>
      <p class="text-muted text-sm">Every upload gets a clean shareable URL. No waiting, no verification needed.</p>
    </div>
    <div class="card">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:.75rem;color:var(--accent2)"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      <h3 style="margin-bottom:.4rem">Download stats</h3>
      <p class="text-muted text-sm">Track how many times your files have been downloaded from your dashboard.</p>
    </div>
    <div class="card">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:.75rem;color:var(--accent2)"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <h3 style="margin-bottom:.4rem">Your files, your control</h3>
      <p class="text-muted text-sm">Delete files at any time. Storage is tracked per account with plan limits.</p>
    </div>
  </div>
</div>

<footer>
  <p>&copy; <%= new Date().getFullYear() %> <%= appName %> &middot; Powered by Alz-Tech</p>
</footer>

</body>
</html>
