<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <title>AlzCloud — Upload & Share Instantly</title>
  <meta name="description" content="Upload any file and get a shareable link instantly — no account needed for files up to 500MB. Register free for 2GB uploads and API access.">
  <meta name="keywords" content="file hosting, upload files, share files online, free file host, image hosting, video hosting, AlzCloud">
  <meta name="author" content="Alz-Tech">
  <link rel="canonical" href="https://cloud.alz.name.ng/">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://cloud.alz.name.ng/">
  <meta property="og:site_name" content="AlzCloud">
  <meta property="og:title" content="AlzCloud — Upload & Share Instantly">
  <meta property="og:description" content="Tap, upload, share. No account needed for files up to 500MB. Register free for 2GB uploads and a developer API.">
  <meta property="og:image" content="https://cloud.alz.name.ng/img/og-cover.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@AlzTech">
  <meta name="twitter:title" content="AlzCloud — Upload & Share Instantly">
  <meta name="twitter:description" content="Tap, upload, share. No account needed for files up to 500MB.">
  <meta name="twitter:image" content="https://cloud.alz.name.ng/img/og-cover.png">

  <meta name="robots" content="index, follow">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233d5afe' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AlzCloud",
    "url": "https://cloud.alz.name.ng",
    "description": "Upload files, images and videos and get instant shareable links. Free for files up to 500MB, no account required.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "offers": [
      { "@type": "Offer", "name": "Free Plan", "price": "0", "priceCurrency": "NGN" },
      { "@type": "Offer", "name": "Starter Plan", "price": "3000", "priceCurrency": "NGN" },
      { "@type": "Offer", "name": "Pro Plan", "price": "5000", "priceCurrency": "NGN" }
    ],
    "provider": { "@type": "Organization", "name": "Alz-Tech", "url": "https://cloud.alz.name.ng" }
  }
  </script>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="logo"><i data-lucide="cloud"></i><span><%= appName %></span></a>
    <div class="topbar-action">
      <% if (user) { %>
        <a href="/dashboard" class="btn btn-outline btn-sm">Dashboard</a>
      <% } else { %>
        <a href="/login" class="btn btn-ghost btn-sm">Sign in</a>
        <a href="/register" class="btn btn-primary btn-sm">Register</a>
      <% } %>
    </div>
  </div>

  <main class="app-main">
    <div class="upload-stage">
      <div id="upload-zone" class="upload-zone" data-endpoint="/upload/anonymous" data-max-bytes="<%= anonMaxBytes %>">
        <svg class="progress-ring" viewBox="0 0 100 100" width="100%" height="100%">
          <circle class="track" cx="50" cy="50" r="44"></circle>
          <circle class="fill" cx="50" cy="50" r="44"></circle>
        </svg>
        <i class="upload-ring-icon" data-lucide="upload-cloud"></i>
        <div class="upload-label">Tap to upload</div>
        <div class="upload-sub">Any file, up to 500MB</div>
      </div>
      <input type="file" id="file-input" style="display:none">

      <div class="filetype-chips">
        <div class="filetype-chip"><i data-lucide="image"></i>Image</div>
        <div class="filetype-chip"><i data-lucide="video"></i>Video</div>
        <div class="filetype-chip"><i data-lucide="music"></i>Audio</div>
        <div class="filetype-chip"><i data-lucide="file-text"></i>Docs</div>
        <div class="filetype-chip"><i data-lucide="package"></i>Any file</div>
      </div>
    </div>

    <div id="upload-result"></div>

    <div class="section">
      <div class="card" style="background:linear-gradient(150deg,var(--brand-tint),var(--violet-tint));border:none">
        <div class="flex items-center gap-2 mb-2">
          <i data-lucide="sparkles" style="color:var(--violet)"></i>
          <strong style="font-family:'Space Grotesk',sans-serif">Want more room?</strong>
        </div>
        <ul class="plan-features" style="margin-bottom:16px">
          <li><i data-lucide="check"></i> Register free — keep every upload in one place</li>
          <li><i data-lucide="check"></i> Upload up to 2GB per file on Starter or Pro</li>
          <li><i data-lucide="check"></i> Get a developer API to upload from your own app</li>
        </ul>
        <div class="flex gap-2">
          <a href="/register" class="btn btn-primary w-full">Create free account</a>
        </div>
        <a href="/plans" class="auth-switch" style="display:block">See all plans →</a>
      </div>
    </div>

    <p class="mini-footer">&copy; <%= new Date().getFullYear() %> <%= appName %> · Powered by Alz-Tech</p>
  </main>

  <%- include('../partials/tabbar', { active: 'home', user }) %>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
