<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☁️</text></svg>">
</head>
<body>

<nav>
  <a href="/" class="logo">☁️ <span><%= appName %></span></a>
  <div class="nav-links">
    <a href="/plans">Pricing</a>
    <% if (user) { %>
      <a href="/dashboard">Dashboard</a>
      <a href="/logout" class="btn btn-outline btn-sm">Sign out</a>
    <% } else { %>
      <a href="/login">Sign in</a>
      <a href="/register" class="btn btn-primary btn-sm">Get started</a>
    <% } %>
  </div>
</nav>

<div class="container">
  <div class="hero">
    <div class="hero-badge">⚡ Fast &amp; Reliable Cloud Storage</div>
    <h1>Store files, images &amp; videos<br><span class="accent">without limits</span></h1>
    <p>Upload once, share anywhere. AlzCloud gives you fast, reliable file hosting with instant shareable links.</p>
    <div class="hero-actions">
      <a href="/register" class="btn btn-primary">Start free &rarr;</a>
      <a href="/plans" class="btn btn-outline">View pricing</a>
    </div>
  </div>

  <div class="stats-grid" style="max-width:700px;margin:0 auto 4rem;">
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">100GB</div>
      <div class="stat-label">Max storage (Business)</div>
    </div>
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">2GB</div>
      <div class="stat-label">Max file size (Business)</div>
    </div>
    <div class="stat-card" style="text-align:center">
      <div class="stat-val">Free</div>
      <div class="stat-label">To get started</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-bottom:4rem;">
    <div class="card">
      <div style="font-size:1.5rem;margin-bottom:.75rem">📁</div>
      <h3 style="margin-bottom:.4rem">Any file type</h3>
      <p class="text-muted text-sm">Documents, images, videos, audio — upload anything and we handle the rest.</p>
    </div>
    <div class="card">
      <div style="font-size:1.5rem;margin-bottom:.75rem">🔗</div>
      <h3 style="margin-bottom:.4rem">Instant public links</h3>
      <p class="text-muted text-sm">Every upload gets a clean shareable URL. No waiting, no verification needed.</p>
    </div>
    <div class="card">
      <div style="font-size:1.5rem;margin-bottom:.75rem">📊</div>
      <h3 style="margin-bottom:.4rem">Download stats</h3>
      <p class="text-muted text-sm">Track how many times your files have been downloaded from your dashboard.</p>
    </div>
    <div class="card">
      <div style="font-size:1.5rem;margin-bottom:.75rem">🔐</div>
      <h3 style="margin-bottom:.4rem">Your files, your control</h3>
      <p class="text-muted text-sm">Delete files at any time. Storage is tracked per account with plan limits.</p>
    </div>
  </div>
</div>

<footer>
  <p>&copy; <%= new Date().getFullYear() %> <%= appName %> &middot; Powered by Alz-Tech</p>
</footer>

</body>
</html>
