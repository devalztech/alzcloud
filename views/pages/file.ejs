<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= file.original_name %> — AlzCloud</title>
  <meta name="description" content="View and download &quot;<%= file.original_name %>&quot; shared via AlzCloud. <%= file.downloads %> downloads so far.">
  <meta name="robots" content="index, follow">
  <meta property="og:type" content="<%= file.file_type === 'image' ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= appUrl %>/f/<%= file.slug %>">
  <meta property="og:site_name" content="AlzCloud">
  <meta property="og:title" content="<%= file.original_name %>">
  <meta property="og:description" content="Shared on AlzCloud &middot; <%= file.file_type %> &middot; <%= file.downloads %> downloads">
  <% if (file.file_type === 'image') { %>
  <meta property="og:image" content="<%= previewUrl %>">
  <% } else { %>
  <meta property="og:image" content="<%= appUrl %>/img/og-cover.png">
  <% } %>
  <meta name="twitter:card" content="<%= file.file_type === 'image' ? 'summary_large_image' : 'summary' %>">
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%233d5afe' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .media-frame { border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); margin-bottom: 16px; background: var(--surface); }
    .media-frame img, .media-frame video { width: 100%; display: block; max-height: 420px; object-fit: contain; background: var(--surface); }
    .embed-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 13px; font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--muted); word-break: break-all; }
  </style>
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="icon-btn"><i data-lucide="chevron-left"></i></a>
    <% if (locals.user) { %><a href="/dashboard" class="btn btn-outline btn-sm">Dashboard</a>
    <% } else { %><a href="/register" class="btn btn-primary btn-sm">Get started</a><% } %>
  </div>

  <main class="app-main no-nav">
    <div class="section">
      <span class="badge badge-<%= file.file_type %>"><%= file.file_type %></span>
      <h2 style="word-break:break-word;line-height:1.3;margin-top:10px;font-size:1.15rem"><%= file.original_name %></h2>
      <p class="text-muted text-sm mt-1">
        <% if (file.username) { %>Uploaded by <strong><%= file.username %></strong> &middot; <% } else { %>Uploaded anonymously &middot; <% } %>
        <%= fileSize %> &middot; <%= file.downloads %> download<%= file.downloads !== 1 ? 's' : '' %>
      </p>

      <% if (file.file_type === 'image') { %>
        <div class="media-frame"><img src="<%= previewUrl %>" alt="<%= file.original_name %>"></div>
      <% } else if (file.file_type === 'video') { %>
        <div class="media-frame">
          <video controls preload="metadata"><source src="<%= previewUrl %>" type="<%= file.mime_type %>">Your browser can't play this video.</video>
        </div>
        <% if (canStream) { %>
        <div class="card mb-2">
          <div class="flex items-center gap-1 text-sm mb-1" style="font-weight:700"><i data-lucide="code-2" style="width:14px;height:14px"></i> Embed this video</div>
          <div class="embed-box">&lt;iframe src="<%= appUrl %>/embed/<%= file.slug %>" width="100%" height="360" allowfullscreen&gt;&lt;/iframe&gt;</div>
          <button class="btn btn-outline btn-sm mt-1" onclick="copyEmbed()">Copy embed code</button>
        </div>
        <% } %>
      <% } else if (file.file_type === 'audio') { %>
        <div class="card mb-2" style="text-align:center">
          <i data-lucide="music" style="width:36px;height:36px;color:var(--brand);margin-bottom:10px"></i>
          <audio controls style="width:100%"><source src="<%= previewUrl %>" type="<%= file.mime_type %>"></audio>
        </div>
      <% } else if (file.mime_type === 'application/pdf') { %>
        <div class="media-frame"><iframe src="<%= previewUrl %>" style="width:100%;height:400px;border:none"></iframe></div>
      <% } else { %>
        <div class="empty-state card mb-2"><i data-lucide="file"></i><p>Preview not available for this file type.</p></div>
      <% } %>

      <div class="copy-row mb-2">
        <input class="form-input" type="text" value="<%= appUrl %>/f/<%= file.slug %>" id="share-url" readonly>
        <button class="btn btn-outline" onclick="copyUrl()"><i data-lucide="copy"></i></button>
      </div>

      <a href="<%= url %>" download="<%= file.original_name %>" class="btn btn-primary btn-block"><i data-lucide="download"></i> Download file</a>
    </div>
    <p class="mini-footer">&copy; <%= new Date().getFullYear() %> <%= appName %></p>
  </main>
</div>
<%- include('../partials/scripts') %>
<script>
function copyUrl() { navigator.clipboard.writeText(document.getElementById('share-url').value); alzToast('Link copied!', 'success'); }
function copyEmbed() {
  const code = `<iframe src="<%= appUrl %>/embed/<%= file.slug %>" width="100%" height="360" allowfullscreen></iframe>`;
  navigator.clipboard.writeText(code); alzToast('Embed code copied!', 'success');
}
</script>
</body>
</html>
