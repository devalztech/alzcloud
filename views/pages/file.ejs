<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Primary SEO -->
  <title><%= file.original_name %> — AlzCloud</title>
  <meta name="description" content="View and download &quot;<%= file.original_name %>&quot; shared via AlzCloud. <%= file.downloads %> downloads so far.">
  <meta name="robots" content="index, follow">

  <!-- Open Graph (WhatsApp, Facebook, Discord previews) -->
  <meta property="og:type" content="<%= file.file_type === 'image' ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= appUrl %>/f/<%= file.slug %>">
  <meta property="og:site_name" content="AlzCloud">
  <meta property="og:title" content="<%= file.original_name %>">
  <meta property="og:description" content="Shared on AlzCloud &middot; <%= file.file_type %> &middot; <%= file.downloads %> downloads">
  <% if (file.file_type === 'image') { %>
  <meta property="og:image" content="<%= appUrl %>/preview/<%= file.username %>/<%= file.slug %>">
  <meta property="og:image:alt" content="<%= file.original_name %>">
  <% } else { %>
  <meta property="og:image" content="<%= appUrl %>/img/og-cover.png">
  <meta property="og:image:alt" content="File shared on AlzCloud">
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="<%= file.file_type === 'image' ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= file.original_name %>">
  <meta name="twitter:description" content="Shared on AlzCloud &middot; <%= file.file_type %> &middot; <%= file.downloads %> downloads">
  <% if (file.file_type === 'image') { %>
  <meta name="twitter:image" content="<%= appUrl %>/preview/<%= file.username %>/<%= file.slug %>">
  <% } else { %>
  <meta name="twitter:image" content="<%= appUrl %>/img/og-cover.png">
  <% } %>

  <!-- Favicon -->
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236c63ff' stroke-width='2'%3E%3Cpath d='M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    html, body { height: 100%; }
    body { display: flex; flex-direction: column; min-height: 100vh; }
    body > main { flex: 1; }
    .embed-box { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: .75rem 1rem; font-family: 'JetBrains Mono', monospace; font-size: .75rem; color: var(--muted); word-break: break-all; }
  </style>
</head>
<body>
<nav>
  <a href="/" class="logo">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
    <span><%= appName %></span>
  </a>
  <div class="nav-links">
    <% if (locals.user) { %>
      <a href="/dashboard">Dashboard</a>
      <a href="/logout" class="btn btn-outline btn-sm">Sign out</a>
    <% } else { %>
      <a href="/login">Sign in</a>
      <a href="/register" class="btn btn-primary btn-sm">Get started</a>
    <% } %>
  </div>
</nav>

<main>
  <div class="container page" style="max-width:660px">
    <div class="card">
      <div style="margin-bottom:1.25rem">
        <span class="file-type-badge badge-<%= file.file_type %>" style="margin-bottom:.75rem;display:inline-block"><%= file.file_type %></span>
        <h2 style="word-break:break-all;line-height:1.3"><%= file.original_name %></h2>
        <p class="text-muted text-sm mt-1">
          Uploaded by <strong><%= file.username %></strong> &middot;
          <%= fileSize %> &middot;
          <%= file.downloads %> download<%= file.downloads !== 1 ? 's' : '' %>
        </p>
      </div>

      <% if (file.file_type === 'image') { %>
        <div style="margin-bottom:1.25rem;border-radius:8px;overflow:hidden;border:1px solid var(--border)">
          <img src="<%= previewUrl %>" alt="<%= file.original_name %>" style="width:100%;display:block;max-height:500px;object-fit:contain;background:var(--bg3)">
        </div>

      <% } else if (file.file_type === 'video') { %>
        <div style="margin-bottom:1.25rem;border-radius:8px;overflow:hidden;border:1px solid var(--border)">
          <video controls style="width:100%;display:block;background:#000" preload="metadata">
            <source src="<%= previewUrl %>" type="<%= file.mime_type %>">
            Your browser does not support video playback.
          </video>
        </div>
        <% if (canStream) { %>
        <div class="card" style="margin-bottom:1rem;padding:1rem">
          <div style="font-size:.8rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.6rem;display:flex;align-items:center;gap:.4rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            Embed this video
          </div>
          <div class="embed-box">&lt;iframe src="<%= appUrl %>/embed/<%= file.slug %>" width="100%" height="360" frameborder="0" allowfullscreen&gt;&lt;/iframe&gt;</div>
          <button class="btn btn-outline btn-sm" style="margin-top:.6rem" onclick="copyEmbed()">Copy embed code</button>
        </div>
        <% } %>

      <% } else if (file.file_type === 'audio') { %>
        <div style="margin-bottom:1.25rem;padding:1.25rem;background:var(--bg3);border-radius:8px;border:1px solid var(--border)">
          <div style="text-align:center;margin-bottom:1rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--accent2)"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <audio controls style="width:100%">
            <source src="<%= previewUrl %>" type="<%= file.mime_type %>">
          </audio>
        </div>

      <% } else { %>
        <div style="padding:2rem;text-align:center;background:var(--bg3);border-radius:8px;border:1px solid var(--border);margin-bottom:1.25rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--muted);margin-bottom:.75rem"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          <p class="text-muted" style="font-size:.875rem">Preview not available for this file type.</p>
        </div>
      <% } %>

      <div class="copy-link-wrap" style="margin-bottom:1rem">
        <input class="form-input" type="text" value="<%= appUrl %>/f/<%= file.slug %>" id="share-url" readonly>
        <button class="btn btn-outline" onclick="copyUrl(this)">Copy link</button>
      </div>

      <a href="<%= url %>" download="<%= file.original_name %>" class="btn btn-primary btn-block">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download file
      </a>
    </div>
  </div>
</main>

<footer>
  <p>&copy; <%= new Date().getFullYear() %> <%= appName %> &middot; Powered by Alz-Tech</p>
</footer>
<script src="/js/app.js"></script>
<script>
function copyUrl(btn) {
  navigator.clipboard.writeText(document.getElementById('share-url').value);
  alzToast('Link copied!', 'success');
}
function copyEmbed() {
  const code = `<iframe src="<%= appUrl %>/embed/<%= file.slug %>" width="100%" height="360" frameborder="0" allowfullscreen></iframe>`;
  navigator.clipboard.writeText(code);
  alzToast('Embed code copied!', 'success');
}
</script>
</body>
</html>
