<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav>
  <a href="/" class="logo"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg><span><%= appName %></span></a>
  <div class="nav-links">
    <% if (user) { %>
      <a href="/dashboard">Dashboard</a>
    <% } else { %>
      <a href="/login">Sign in</a>
    <% } %>
  </div>
</nav>
<div class="container page" style="max-width:480px;text-align:center">
  <div style="font-size:4rem;margin-bottom:1rem">⚠️</div>
  <h2 style="margin-bottom:.5rem"><%= title %></h2>
  <p class="text-muted" style="margin-bottom:1.5rem"><%= message %></p>
  <a href="/" class="btn btn-outline">Go home</a>
</div>
<footer>
  <p>&copy; <%= new Date().getFullYear() %> <%= appName %> &middot; Powered by Alz-Tech</p>
</footer>
</body>
</html>
