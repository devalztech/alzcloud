<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %> — <%= appName %></title>
  <meta name="csrf-token" content="<%= locals.csrfToken || '' %>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">
  <div class="topbar">
    <a href="/" class="logo"><i data-lucide="cloud"></i><span><%= appName %></span></a>
    <% if (user) { %><a href="/dashboard" class="btn btn-outline btn-sm">Dashboard</a>
    <% } else { %><a href="/login" class="btn btn-ghost btn-sm">Sign in</a><% } %>
  </div>
  <main class="app-main no-nav">
    <div class="section text-center" style="padding-top:60px">
      <i data-lucide="alert-triangle" style="width:48px;height:48px;color:var(--warning);margin-bottom:16px"></i>
      <h2 style="margin-bottom:8px"><%= title %></h2>
      <p class="text-muted mb-3"><%= message %></p>
      <a href="/" class="btn btn-outline">Go home</a>
    </div>
  </main>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
