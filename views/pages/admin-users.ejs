<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — <%= appName %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav>
  <a href="/" class="logo">☁️ <span><%= appName %></span></a>
  <div class="nav-links">
    <a href="/dashboard">Dashboard</a>
    <a href="/admin">Admin</a>
    <a href="/logout" class="btn btn-outline btn-sm">Sign out</a>
  </div>
</nav>

<div class="container page">
  <div class="flex items-center justify-between" style="margin-bottom:1.5rem">
    <h2>All Users</h2>
    <a href="/admin" class="btn btn-outline btn-sm">&larr; Back</a>
  </div>

  <div class="card">
    <div style="overflow-x:auto">
      <table class="files-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Plan</th>
            <th>Storage</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for (var i = 0; i < users.length; i++) { var u = users[i]; %>
          <tr>
            <td>
              <strong><%= u.username %></strong>
              <% if (u.is_admin) { %>
                <span style="font-size:.7rem;background:#f5c84222;color:#f5c842;padding:.1rem .4rem;border-radius:4px;margin-left:.4rem">admin</span>
              <% } %>
            </td>
            <td class="text-muted"><%= u.email %></td>
            <td>
              <select class="form-input" style="padding:.25rem .5rem;font-size:.8rem;width:auto" onchange="changePlan(<%= u.id %>, this.value)">
                <option <%= u.plan==='free' ? 'selected' : '' %>>free</option>
                <option <%= u.plan==='pro' ? 'selected' : '' %>>pro</option>
                <option <%= u.plan==='business' ? 'selected' : '' %>>business</option>
              </select>
            </td>
            <td class="text-muted"><%= u.storageFormatted %></td>
            <td class="text-muted"><%= u.joinedDate %></td>
            <td>
              <button class="btn btn-danger btn-sm" onclick="deleteUser(<%= u.id %>)">Delete</button>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<footer>
  <p>&copy; <%= new Date().getFullYear() %> <%= appName %> &middot; Powered by Alz-Tech</p>
</footer>
<script>
async function changePlan(id, plan) {
  await fetch('/admin/users/' + id + '/plan', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ plan })
  });
}
async function deleteUser(id) {
  if (!confirm('Delete this user and all their files?')) return;
  const r = await fetch('/admin/users/' + id, { method: 'DELETE' });
  if ((await r.json()).success) location.reload();
}
</script>
</body>
</html>
